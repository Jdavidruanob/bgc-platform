# API
COOP_API_BASE_URL=http://localhost:8001
COOP_API_TOKEN=mock-secret

# Telegram
TELEGRAM_BOT_TOKEN=<tu-token-de-@BotFather>
TELEGRAM_OPERADOR_CHAT_ID=<tu-chat-id>

# OpenAI
OPENAI_API_KEY=<tu-api-key>

# Opcionales
LOG_LEVEL=DEBUG

# WhatsApp Cloud API (opcional). Si no se configuran, el bot usa únicamente
# el fallback de enlaces wa.me para notificar a los socios.
WHATSAPP_CLOUD_API_TOKEN=<token-de-Meta-Cloud-API>
WHATSAPP_PHONE_NUMBER_ID=<phone-number-id-de-Meta>
